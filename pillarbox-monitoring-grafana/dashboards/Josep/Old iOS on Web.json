            "data": "{\n  \"size\": 0,\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        {\n          \"range\": {\n            \"@timestamp\": {\n              \"gte\": \"${__from}\",\n              \"lte\": \"${__to}\"\n            }\n          }\n        },\n        {\n          \"query_string\": {\n            \"query\": \"event_name:START AND session.player.platform:Web AND session.os.name:iOS\"\n          }\n        }\n      ]\n    }\n  },\n  \"aggs\": {\n    \"ios_versions\": {\n      \"filters\": {\n        \"other_bucket_key\": \"other_versions\",\n        \"filters\": {\n          \"ios16\": { \"query_string\": { \"query\": \"session.os.version:16*\" } },\n          \"ios15\": { \"query_string\": { \"query\": \"session.os.version:15*\" } },\n          \"ios14\": { \"query_string\": { \"query\": \"session.os.version:14*\" } },\n          \"ios13\": { \"query_string\": { \"query\": \"session.os.version:13*\" } },\n          \"ios12\": { \"query_string\": { \"query\": \"session.os.version:12*\" } },\n          \"ios11\": { \"query_string\": { \"query\": \"session.os.version:11*\" } },\n          \"ios10\": { \"query_string\": { \"query\": \"session.os.version:10*\" } },\n          \"ios9\": { \"query_string\": { \"query\": \"session.os.version:9*\" } },\n          \"ios8\": { \"query_string\": { \"query\": \"session.os.version:8*\" } }\n        }\n      },\n      \"aggs\": {\n        \"count_per_version\": {\n          \"cardinality\": {\n            \"field\": \"session.device.id\"\n          }\n        }\n      }\n    }\n  }\n}",
